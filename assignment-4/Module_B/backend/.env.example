# =============================================
# GateGuard Backend - Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# App
NODE_ENV=development
PORT=5000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gateguard_db
DB_USER=postgres
DB_PASSWORD=yourpasswordhere
DB_MAX_CONNECTIONS=20

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# CORS - where the frontend runs
FRONTEND_URL=http://localhost:5173

# SMTP (for OTP / security emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=GateGuard <your-gmail@gmail.com>

# Auth security controls
OTP_EXPIRES_MINUTES=15
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Audit log file path (relative to backend root)
AUDIT_LOG_PATH=logs/audit.log
