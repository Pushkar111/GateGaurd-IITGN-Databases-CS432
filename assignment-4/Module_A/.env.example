# GateGuard Assignment 4 - Sharding Environment Config
# Copy this file to .env and fill in your actual values

# local PostgreSQL (source DB, read-only during migration)
LOCAL_DB_HOST=localhost
LOCAL_DB_PORT=5432
LOCAL_DB_NAME=gateguard
LOCAL_DB_USER=postgres
LOCAL_DB_PASSWORD=root

# shard 0 - Docker container gateguard-shard-0 on port 5433
SHARD_0_HOST=localhost
SHARD_0_PORT=5433
SHARD_0_DB=gateguard_shard_0
SHARD_0_USER=postgres
SHARD_0_PASSWORD=shard_root

# shard 1 - Docker container gateguard-shard-1 on port 5434
SHARD_1_HOST=localhost
SHARD_1_PORT=5434
SHARD_1_DB=gateguard_shard_1
SHARD_1_USER=postgres
SHARD_1_PASSWORD=shard_root

# shard 2 - Docker container gateguard-shard-2 on port 5435
SHARD_2_HOST=localhost
SHARD_2_PORT=5435
SHARD_2_DB=gateguard_shard_2
SHARD_2_USER=postgres
SHARD_2_PASSWORD=shard_root

# router config
NUM_SHARDS=3
