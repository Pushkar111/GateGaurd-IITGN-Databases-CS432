# Ignore markdown files except README.md
*.md
!README.md

# Ignore LaTeX source files
*.tex
!assignment-4/GateGuard_Assignment4_Report.tex

# Ignore PlantUML / WSD diagram source files
*.wsd
*.puml

# Ignore node_modules of frontend and backend
node_modules

# Ignore dist folder of frontend
dist

# Ignore .env files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore runtime logs for Module B backend
assignment-2/Module_B/backend/logs/*.log
assignment-3/Module_B/backend/logs/*.log
assignment-4/Module_B/backend/logs/*.log

# ignore zip files
*.zip


# python cache
__pycache__

# toc, aux, log, out, etc. files generated by LaTeX
*.toc
*.aux
*.log
*.out

# excalidraw files
*.excalidraw

# pdf inside the intial documents
Intial-Documentations/*.pdf